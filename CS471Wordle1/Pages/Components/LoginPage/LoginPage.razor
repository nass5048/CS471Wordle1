@page "/"
@using WordleAPI
@using WordleAPI.Classes
@using System.ComponentModel.DataAnnotations
@inject Services.SpinnerService SpinnerService
@inject DataBase db
@inject HttpClient Http
@inject Login UserLogin
@inject NavigationManager NavigationManager
