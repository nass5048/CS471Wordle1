 *@
<EditForm Model="model" OnValidSubmit="Login">

    <div class="d-flex justify-content-center mt-5">
        <div class="card p-4 shadow" style="width: 350px;">
            <h4 class="text-center mb-3">Login</h4>

            <div class="mb-3">
                <label class="form-label">Username</label>
                <InputText class="form-control" @bind-Value="model.Username" />
                <ValidationMessage For="@(() => model.Username)" />
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <InputText type="password" class="form-control" @bind-Value="model.Password" />
                <ValidationMessage For="@(() => model.Password)" />
            </div>

            <button class="btn btn-success w-100" type="submit">Login</button>
            <div style="margin-top:20px"/>
            <button class="btn btn-success w-100" @onclick=@(()=>NavigationManager.NavigateTo("/signup"))>Sign Up</button>
            <div class="text-center mt-3 text-danger">@message</div>
        </div>
    </div>
</EditForm>

@code {
    LoginModel model = new();
    string message = "";

    async Task Login()
    {
        if (string.IsNullOrWhiteSpace(model.Username) || string.IsNullOrWhiteSpace(model.Password))
        {
            message = "Please enter both fields.";
            return;
        }

        message = $"Attempting login for {model.Username}";
        SpinnerService.Show();
        var test = await Http.GetFromJsonAsync<DataBase>("https://localhost:7160/api/data");
        if (test != null)
            db.UpdateStoredDB(test);
        foreach (var login in db.Login)
        {
            if (login.Username == model.Username && login.Password == model.Password)
            {
				UserLogin.SetUserLogin(login);
                SpinnerService.Hide();
                NavigationManager.NavigateTo("/wordle");
                break;
            }
        }
        SpinnerService.Hide();
    }
    public class LoginModel
    {
        [Required]
        public string Username { get; set; }

        [Required]
        public string Password { get; set; }
    }
}
