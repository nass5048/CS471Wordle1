@* @page "/wordle" *@

@using System.Text.Json
@using WordleAPI
@using WordleAPI.Classes;
@using CS471Wordle1.Pages.Components
@using WordleBackend.Enums
@inject Services.SpinnerService SpinnerService
@inject Login UserLogin
@inject DataBase db
@inject HttpClient Http
@* @inject HttpClient Http *@

<PageTitle>Wordle</PageTitle>

@if (correctWord != null)
{
	  <WordleKeyboardHost Solution=@correctWord OnGameCompleted="completeDaily" challenge="challenge" gameMode="gameMode"/> 
	  if(challenge == Challenge.None || challenge == Challenge.HardMode){
		<div class="top-right">

			<RobotWordle Solution=@correctWord Hide=@HideRobot/>
		</div>

	  }
}
<style>
	.top-right {
		position: fixed;
		top: 75px;
		right: 25px;
		z-index: 9999;
	}
</style>

@code {
	[Parameter]
	public GameMode gameMode { get; set; }
	[Parameter]
	public Challenge challenge { get; set; }



	string? correctWord{ get;set; }
	WordResponse? dailyWord { get; set; }

	bool HideRobot { get; set; } = true;
	override protected async Task OnInitializedAsync()
	{
		await db.LoadData(Http);
		try
		{

			SpinnerService.Show();
			if (gameMode == GameMode.Daily)
			{
				var word = db.DailyWords.First(w => w.Date == DateOnly.FromDateTime(DateTime.Today)).Word;
				if (string.IsNullOrWhiteSpace(word))
				{
					word = "stare";
				}
				dailyWord = new WordResponse() { Solution = word };
			}
			else
			{
				dailyWord = new WordResponse() { Solution = "stair" };//await Http.GetFromJsonAsync<WordResponse>("daily-word.json");
			}
			var date = DateTime.Today.ToString("yyyy-MM-dd");

			correctWord = dailyWord.Solution;
		}
		catch (Exception ex)
		{
			Console.Error.WriteLine(ex);
		}

		//await stats.LoadAsync();
		SpinnerService.Hide();
	}

	public class WordResponse
	{
		public string Solution { get; set; }
	}

	public void completeDaily()
	{
		HideRobot = false;
	}
}