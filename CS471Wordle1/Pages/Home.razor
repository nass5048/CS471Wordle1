@using CS471Wordle1.Pages.Components
@using WordleBackend.Enums
@using WordleAPI.Classes
@inject NavigationManager Navigation
@inject Login UserLogin

@page "/"

<EditForm Model="@model">

    <div class="container mt-5">

        <h1 class="fw-bold text-center mb-4">Wordle+</h1>
        <p class="text-center text-muted mb-5">
            Customize your game and start playing instantly.
        </p>

        <div class="card shadow p-4 mx-auto" style="max-width: 600px;">

            <h4 class="fw-bold mb-3">Game Settings</h4>

            <!-- Game Mode -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Game Mode</label>
                <select @bind="model.gameMode" class="form-select">
                    @foreach (var mode in Enum.GetValues(typeof(GameMode)))
                    {
                        <option value="@mode">@mode</option>
                    }
                </select>
            </div>

            <!-- Difficulty -->
            <div class="mb-3">
                <label class="form-label fw-semibold">Difficulty</label>
                <select @bind="model.challenge" class="form-select">
                    @foreach (var diff in Enum.GetValues(typeof(Challenge)))
                    {
                        <option value="@diff">@diff</option>
                    }
                </select>
            </div>

            

            <button class="btn btn-success w-100 mt-3" @onclick="StartGame">
                Start Game
            </button>

        </div>
    </div>
</EditForm>
@if(UserLogin.UserPermission != Permission.Guest)
	{
		<div class="top-left">
			<StatsViewer />
		</div>
		
	}

<style>
    .top-left {
        position: absolute;
        top: 20px;
        left: 20px;
        z-index: 9999;
    }
</style>


@code {


    private void StartGame()
    {
        Navigation.NavigateTo($"/game/{model.gameMode}/{model.challenge}");
    }


    private WordleSelector model = new WordleSelector();

    public class WordleSelector
    {
        public Challenge challenge { get; set; }
        public GameMode gameMode { get; set; }
    }
}
